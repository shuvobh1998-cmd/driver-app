# Release signing for the driver app. Copy this file to `android/key.properties`
# (gitignored) and fill in your upload-key details. When this file is absent,
# release builds fall back to debug signing so CI and dev machines still build.
#
# 1. Generate an upload keystore (once, kept OUT of the repo):
#      keytool -genkey -v -keystore ~/driver-upload.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias upload
# 2. Copy this file and point storeFile at that keystore.
# 3. Build the store bundle:  flutter build appbundle --flavor prod -t lib/main_prod.dart

storePassword=changeme
keyPassword=changeme
keyAlias=upload
# Absolute path, or relative to the android/app directory.
storeFile=/absolute/path/to/driver-upload.jks
